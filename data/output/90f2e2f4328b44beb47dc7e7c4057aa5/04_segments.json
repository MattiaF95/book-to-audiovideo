{
  "segments": [
    {
      "segment_id": "1",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Non muoverti, sussurrò Marco, stringendo la torcia spenta. Il battito del suo cuore risuonava nel silenzio della biblioteca. Credo che ci sia... qualcuno.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 0,
      "end_offset": 143,
      "emotion_hint": null,
      "importance_score": 0.5
    },
    {
      "segment_id": "2",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Dall'angolo buio della stanza giunse un rumore metallico. Clang. Poi, una risata sommessa, quasi impercettibile.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 144,
      "end_offset": 266,
      "emotion_hint": null,
      "importance_score": 0.3
    },
    {
      "segment_id": "3",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Chi va là?",
      "segment_type": "dialogue",
      "speaker_hint": "Giulia",
      "resolved_speaker_id": null,
      "start_offset": 267,
      "end_offset": 283,
      "emotion_hint": "fear",
      "importance_score": 0.8
    },
    {
      "segment_id": "4",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Non era tipo da spaventarsi facilmente, ma quella situazione (assurda, se ci pensava bene) le stava togliendo il respiro.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 284,
      "end_offset": 414,
      "emotion_hint": null,
      "importance_score": 0.4
    },
    {
      "segment_id": "5",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Fatti vedere!",
      "segment_type": "dialogue",
      "speaker_hint": "Giulia",
      "resolved_speaker_id": null,
      "start_offset": 415,
      "end_offset": 429,
      "emotion_hint": "anger",
      "importance_score": 0.7
    },
    {
      "segment_id": "6",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "L'ombra si mosse lentamente verso la luce della luna.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 430,
      "end_offset": 463,
      "emotion_hint": null,
      "importance_score": 0.2
    },
    {
      "segment_id": "7",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Era un uomo alto, vestito con un cappotto logoro.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 464,
      "end_offset": 498,
      "emotion_hint": null,
      "importance_score": 0.1
    },
    {
      "segment_id": "8",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Guardò i due ragazzi e disse con calma piatta: Cercate la verità? O volete solo... fuggire?",
      "segment_type": "dialogue",
      "speaker_hint": "mysterious man",
      "resolved_speaker_id": null,
      "start_offset": 499,
      "end_offset": 623,
      "emotion_hint": "neutral",
      "importance_score": 0.9
    },
    {
      "segment_id": "9",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "La risposta costa 1.500 euro. Cash.",
      "segment_type": "dialogue",
      "speaker_hint": "mysterious man",
      "resolved_speaker_id": null,
      "start_offset": 624,
      "end_offset": 655,
      "emotion_hint": "menace",
      "importance_score": 0.8
    },
    {
      "segment_id": "10",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Marco sbuffò, incredulo.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 656,
      "end_offset": 683,
      "emotion_hint": null,
      "importance_score": 0.3
    },
    {
      "segment_id": "11",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Millecinquecento euro? Tu sei pazzo! E poi, chi usa più i contanti nel 2026?",
      "segment_type": "dialogue",
      "speaker_hint": "Marco",
      "resolved_speaker_id": null,
      "start_offset": 684,
      "end_offset": 755,
      "emotion_hint": "anger",
      "importance_score": 0.8
    },
    {
      "segment_id": "12",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Ragazzi... guardate là!",
      "segment_type": "dialogue",
      "speaker_hint": "Giulia",
      "resolved_speaker_id": null,
      "start_offset": 756,
      "end_offset": 774,
      "emotion_hint": "excitement",
      "importance_score": 0.7
    },
    {
      "segment_id": "13",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "indicando lo schermo del computer sulla scrivania.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 775,
      "end_offset": 808,
      "emotion_hint": null,
      "importance_score": 0.2
    },
    {
      "segment_id": "14",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Il monitor si era acceso da solo, mostrando una sequenza infinita di codice: 01101001 01101110 01100110.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 809,
      "end_offset": 876,
      "emotion_hint": null,
      "importance_score": 0.4
    },
    {
      "segment_id": "15",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "L'uomo sorrise misteriosamente.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 877,
      "end_offset": 906,
      "emotion_hint": null,
      "importance_score": 0.1
    },
    {
      "segment_id": "16",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Il tempo stringe. Tic-tac, tic-tac...",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": null,
      "start_offset": 907,
      "end_offset": 936,
      "emotion_hint": null,
      "importance_score": 0.2
    }
  ]
}