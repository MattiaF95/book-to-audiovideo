  "segments": [
    {
      "segment_id": "1",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Non muoverti, sussurrò Marco, stringendo la torcia spenta. Il battito del suo cuore risuonava nel silenzio della biblioteca. Credo che ci sia... qualcuno.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 0,
      "end_offset": 69,
      "emotion_hint": null,
      "importance_score": 0.5
    },
    {
      "segment_id": "2",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Dall'angolo buio della stanza giunse un rumore metallico. Clang. Poi, una risata sommessa, quasi impercettibile.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 70,
      "end_offset": 141,
      "emotion_hint": null,
      "importance_score": 0.3
    },
    {
      "segment_id": "3",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Chi va là? gridò Giulia, la voce che tradiva un brivido di terrore.",
      "segment_type": "dialogue",
      "speaker_hint": "Giulia",
      "resolved_speaker_id": "Giulia",
      "start_offset": 142,
      "end_offset": 202,
      "emotion_hint": "fear",
      "importance_score": 0.8
    },
    {
      "segment_id": "4",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Non era tipo da spaventarsi facilmente, ma quella situazione (assurda, se ci pensava bene) le stava togliendo il respiro.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 203,
      "end_offset": 294,
      "emotion_hint": null,
      "importance_score": 0.4
    },
    {
      "segment_id": "5",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Fatti vedere!",
      "segment_type": "dialogue",
      "speaker_hint": "Giulia",
      "resolved_speaker_id": "Giulia",
      "start_offset": 295,
      "end_offset": 306,
      "emotion_hint": "anger",
      "importance_score": 0.7
    },
    {
      "segment_id": "6",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "L'ombra si mosse lentamente verso la luce della luna. Era un uomo alto, vestito con un cappotto logoro.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 307,
      "end_offset": 386,
      "emotion_hint": null,
      "importance_score": 0.2
    },
    {
      "segment_id": "7",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Guardò i due ragazzi e disse con calma piatta: Cercate la verità? O volete solo... fuggire?",
      "segment_type": "dialogue",
      "speaker_hint": "unknown",
      "resolved_speaker_id": "unknown",
      "start_offset": 387,
      "end_offset": 463,
      "emotion_hint": "neutral",
      "importance_score": 0.9
    },
    {
      "segment_id": "8",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "La risposta costa 1.500 euro. Cash.",
      "segment_type": "dialogue",
      "speaker_hint": "unknown",
      "resolved_speaker_id": "unknown",
      "start_offset": 464,
      "end_offset": 498,
      "emotion_hint": "menace",
      "importance_score": 0.8
    },
    {
      "segment_id": "9",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Marco sbuffò, incredulo.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 499,
      "end_offset": 514,
      "emotion_hint": null,
      "importance_score": 0.3
    },
    {
      "segment_id": "10",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Millecinquecento euro? Tu sei pazzo! E poi, chi usa più i contanti nel 2026?",
      "segment_type": "dialogue",
      "speaker_hint": "Marco",
      "resolved_speaker_id": "Marco",
      "start_offset": 515,
      "end_offset": 593,
      "emotion_hint": "anger",
      "importance_score": 0.9
    },
    {
      "segment_id": "11",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Ragazzi... guardate là! interruppe Giulia, indicando lo schermo del computer sulla scrivania.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 594,
      "end_offset": 673,
      "emotion_hint": null,
      "importance_score": 0.4
    },
    {
      "segment_id": "12",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Il monitor si era acceso da solo, mostrando una sequenza infinita di codice: 01101001 01101110 01100110.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 674,
      "end_offset": 755,
      "emotion_hint": null,
      "importance_score": 0.2
    },
    {
      "segment_id": "13",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "L'uomo sorrise misteriosamente.",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 756,
      "end_offset": 774,
      "emotion_hint": null,
      "importance_score": 0.1
    },
    {
      "segment_id": "14",
      "chunk_id": "b9b2fa7fe095",
      "raw_text": "Il tempo stringe. Tic-tac, tic-tac...",
      "segment_type": "narration",
      "speaker_hint": null,
      "resolved_speaker_id": "narrator",
      "start_offset": 775,
      "end_offset": 800,
      "emotion_hint": null,
      "importance_score": 0.1
    }
  ]
}